DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=__cambiami__
APP_PORT=8002
ALLOWED_HOSTS=staging.plancia.agescicampania.org,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://staging.plancia.agescicampania.org
BASE_URL=https://staging.plancia.agescicampania.org

# Database staging (separato dalla produzione)
POSTGRES_DB=plancia_staging
POSTGRES_USER=plancia_staging
POSTGRES_PASSWORD=__cambiami__
DATABASE_URL=postgres://plancia_staging:__cambiami__@db:5432/plancia_staging

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Email — in staging usare Mailpit per non inviare mail reali
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false
DEFAULT_FROM_EMAIL=staging-plancia@agescicampania.org
MAILPIT_SMTP_HOST=mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_INTERNAL_URL=http://mailpit:8025

# Notifiche errori agli admin (staging: facoltativo)
ADMIN_EMAILS=
SERVER_EMAIL=staging-plancia@agescicampania.org

# Google OAuth / Drive — usare credenziali separate per staging
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://staging.plancia.agescicampania.org/drive/oauth/callback/
GOOGLE_GMAIL_SMTP_REDIRECT_URI=https://staging.plancia.agescicampania.org/impostazioni/gmail-smtp/oauth/callback/

# API REST (CORS) — origini autorizzate per il client mobile
CORS_ALLOWED_ORIGINS=

# Export riassuntivo diari
EXPORT_DIARI_SOGLIA_ASYNC=50

# Social auth — lascia vuoti per disattivare
SOCIAL_GOOGLE_CLIENT_ID=
SOCIAL_GOOGLE_CLIENT_SECRET=
SOCIAL_MICROSOFT_CLIENT_ID=
SOCIAL_MICROSOFT_CLIENT_SECRET=
SOCIAL_APPLE_CLIENT_ID=
SOCIAL_APPLE_TEAM_ID=
SOCIAL_APPLE_KEY_ID=
SOCIAL_APPLE_PRIVATE_KEY=
