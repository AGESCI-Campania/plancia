DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=__cambiami__
APP_PORT=8001
ALLOWED_HOSTS=staging.agescicampania.org,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://staging.agescicampania.org
BASE_URL=https://staging.agescicampania.org

# Database staging (separato dalla produzione)
POSTGRES_DB=plancia_staging
POSTGRES_USER=plancia_staging
POSTGRES_PASSWORD=__cambiami__
DATABASE_URL=postgres://plancia_staging:__cambiami__@db:5432/plancia_staging

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Email — in staging usare Mailpit per non inviare mail reali
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false
DEFAULT_FROM_EMAIL=staging-plancia@agescicampania.org
MAILPIT_SMTP_HOST=mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_INTERNAL_URL=http://mailpit:8025

# Google OAuth / Drive — usare credenziali separate per staging
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
