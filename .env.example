# Template variabili di PRODUZIONE (generato/aggiornato da deploy/configure-prod.sh)
DJANGO_SETTINGS_MODULE=config.settings.prod
# ATTENZIONE: cambiare DJANGO_DEBUG richiede un REDEPLOY/restart dei container.
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=__cambiami__
APP_PORT=8000
ALLOWED_HOSTS=plancia.agescicampania.org
CSRF_TRUSTED_ORIGINS=https://plancia.agescicampania.org
BASE_URL=https://plancia.agescicampania.org

# Database
POSTGRES_DB=plancia
POSTGRES_USER=plancia
POSTGRES_PASSWORD=__cambiami__
DATABASE_URL=postgres://plancia:__cambiami__@db:5432/plancia

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Email — SMTP fallback (usato solo se il provider in Impostazioni è SMTP)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=plancia@agescicampania.org
# Notifiche errori (404, 500): lista indirizzi separati da virgola (vuoto = disabilitate)
ADMIN_EMAILS=admin@esempio.it
SERVER_EMAIL=plancia@agescicampania.org

# Mailpit (debug email in produzione — solo con profilo "mailpit")
# In nginx-docker mode i default (mailpit:1025, mailpit:8025) sono corretti.
# In nginx-host/apache-host mode: impostare localhost:1025 e http://localhost:8025
# + esporre la porta 8025 su loopback nel docker-compose.yml.
MAILPIT_SMTP_HOST=mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_INTERNAL_URL=http://mailpit:8025

# Google OAuth / Drive
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# API REST (CORS) — lista delle origini autorizzate per il client mobile
# Formato: URL separati da virgola  es. https://app.agescicampania.org,https://staging.app.agescicampania.org
CORS_ALLOWED_ORIGINS=

# Export riassuntivo diari — soglia diari oltre cui l'export xlsx/ods diventa asincrono
EXPORT_DIARI_SOGLIA_ASYNC=50
