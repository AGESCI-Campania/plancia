# Template variabili di PRODUZIONE (generato/aggiornato da deploy/configure-prod.sh)
DJANGO_SETTINGS_MODULE=config.settings.prod
# ATTENZIONE: cambiare DJANGO_DEBUG richiede un REDEPLOY/restart dei container.
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=__cambiami__
APP_PORT=8000
ALLOWED_HOSTS=plancia.agescicampania.org
CSRF_TRUSTED_ORIGINS=https://plancia.agescicampania.org

# Database
POSTGRES_DB=plancia
POSTGRES_USER=plancia
POSTGRES_PASSWORD=__cambiami__
DATABASE_URL=postgres://plancia:__cambiami__@db:5432/plancia

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Email (SMTP)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=plancia@agescicampania.org

# Google OAuth / Drive
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
